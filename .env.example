# ===========================================
# AI CanvasPro 环境变量配置文件
# 复制此文件为 .env 并修改配置
# ===========================================

# ---- 端口 ----
AICANVAS_PORT=8777

# ---- 日志级别 ----
# off:    完全静默（默认），无 HTTP 请求日志
# basic:  标准 HTTP 访问日志（类似 Apache/Nginx access log）
# verbose: 详细日志（含时间戳、客户端 IP、User-Agent）
AIC_LOG_LEVEL=basic

# ---- 安全配置 ----
# 部署到云端时，替换为你的实际访问域名（必填）
# 多个域名用逗号分隔
AIC_ALLOWED_ORIGINS=http://localhost:8777

# 可选：本地访问令牌
# AIC_LOCAL_TOKEN=

# ---- 订阅授权服务器（一般无需修改）----
# AIC_SUBSCRIPTION_API_BASE=

# ---- 代理（如需科学上网）----
# HTTP_PROXY=
# HTTPS_PROXY=

# ---- 数据目录（可选，默认容器内 /app/ 下）----
# 如需将数据存储到容器外其他路径（如 NFS 挂载），可在此指定
# AIC_USER_DIR=/app/user
# AIC_OUTPUT_DIR=/app/output
# AIC_DATA_DIR=/app/data
# AIC_UPLOADS_DIR=/app/data/uploads
