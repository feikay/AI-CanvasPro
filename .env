# ===========================================
# AI CanvasPro 环境变量配置文件
# 复制此文件为 .env 并修改配置
# ===========================================

# ---- 端口 ----
AICANVAS_PORT=8777

# ---- 安全配置 ----
# 部署到云端时，替换为你的实际访问域名（必填）
# 多个域名用逗号分隔
AIC_ALLOWED_ORIGINS=http://localhost:8777

# 可选：本地访问令牌
# AIC_LOCAL_TOKEN=

# ---- 订阅授权服务器（一般无需修改）----
# AIC_SUBSCRIPTION_API_BASE=

# ---- 代理（如需科学上网）----
# HTTP_PROXY=
# HTTPS_PROXY=
